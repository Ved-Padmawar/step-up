# Neon Postgres (required)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Auth.js / session (required)
AUTH_SECRET=

# Optional: seed the first admin user (`pnpm db:seed-admin`)
ADMIN_NAME=
ADMIN_MOBILE=
ADMIN_PASSWORD=

# Vercel Blob (required before photo uploads)
# BLOB_READ_WRITE_TOKEN=
